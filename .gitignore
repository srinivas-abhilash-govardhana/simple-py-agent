# --- Virtual environments ---
.venv/
venv/
ENV/
env/

# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Test / type-check / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/

# --- Coverage / test reports ---
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml
junit.xml

# --- Build / packaging artifacts ---
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- Logs ---
*.log

# --- Local env/secrets (do not commit) ---
.env
.env.*
!.env.example

# --- IDE/editor ---
.vscode/
.idea/
*.iml

# --- OS ---
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride

# --- uv (optional) ---
# If you ever enable "uv cache in project", ignore it:
.uv/

# --- Local DB / runtime data (optional) ---
*.sqlite3
*.db